    endif 
    
    hotkey 'target closest grey monster' 
    getlabel backpack pingCheck
    if skill 'magery' >= 60 and not insysmsg 'No one matching that was found on your screen.'
        overhead '† Monster †' 88 lasttarget  
        getlabel backpack pingCheck      
