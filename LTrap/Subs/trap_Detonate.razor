    if rhandempty and not casting  
        if @find! _t_equip_rhand  backpack
            @getlabel! backpack _bp
            dclick  _t_equip_rhand
            sysmsg "detonate rhand equip - _rhand_in_use {{_rhand_in_use}}" 79
        endif
    endif
else
