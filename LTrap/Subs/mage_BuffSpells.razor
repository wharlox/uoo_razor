// Buff - Reactive Armor / Protection / Bless


if not cooldown 'Reactive' and not hidden and mana > 20 and not findbuff 'reactive armor' 
    cast 'reactive armor'
    wait 100
    if not insysmsg 'You do not have that spell'
        while casting 
            wait 100
        endwhile
        wait 600
        cooldown 'Reactive' 10000
    endif  
endif 

