
#sysmsg "_util_msg - start"
#@setvar! _this_script "Play Script: deposit-loadout\functions\_util_msg"

if not timerexists _util_debug_msg_timer
    sysmsg "msg - just started"
else
    sysmsg "msg {{_util_debug_msg_timer}}"
endif

@settimer _util_debug_msg_timer 0



#### continue script chain
hotkey "Play Script: deposit-loadout\functions\_util_continue_script_chain"
foreach _itr in _util_continue_script_chain 
    hotkey _itr
endfor