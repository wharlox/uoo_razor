if not timerexists _util_loop
    @settimer _util_loop 0
endif
#### list initializations - edit options below
if not listexists _util__house__ban_bot__ignores
    @createlist  _util__house__ban_bot__ignores
endif

if not listexists __util__do_not_ban__list
    @createlist  __util__do_not_ban__list
endif

if not listexists __util__house__ban_bot__banned
    @createlist   __util__house__ban_bot__banned
endif



@setvar!  __util__auto_close_house_gump  1

#### editable options - use >info on a player and add their serial, one per line
# @pushlist  __util__do_not_ban__list  0x0










#### logic - dont edit below
### cleanup tmp items
while inlist  __util__do_not_ban__list  0  
    @poplist  __util__do_not_ban__list  0
endwhile
while  inlist  __util__do_not_ban__list  0x0
    @poplist  __util__do_not_ban__list  0x0
endwhile

@setvar __util_ban_bot_sound__delay  6150
if not timerexists _sound
    @settimer  _sound  __util_ban_bot_sound__delay
endif


if not dead
    @clearsysmsg

    if targetexists
        hotkey 'cancel current target'
    endif
    
    if not hidden
        skill "hiding"
    endif

    hotkey 'Next non-friendly player target'
    #@getlabel! backpack _bp
    wait 100

    if not insysmsg 'No one matching that was found on your screen.'
        @setvar!  _target  lasttarget
        if  not inlist  _util__house__ban_bot__ignores  _target  and  not inlist  __util__do_not_ban__list  _target  and not inlist  __util__house__ban_bot__banned  _target
            say "i ban thee" 
            wft 500
            target _target
            wait 100
            #@getlabel! backpack _bp
            if insysmsg "You cannot eject a friend of the house!"
                @pushlist  _util__house__ban_bot__ignores  _target 
            endif  
            if insysmsg "This person is already banned"
                @pushlist  __util__house__ban_bot__banned  _target
            endif
            if  insysmsg "has been banned from this house"
                @pushlist  __util__house__ban_bot__banned  _target
                if timer _sound >= __util_ban_bot_sound__delay
                    if findtype 'sackbut'
                        dclicktype 'sackbut'
                    elseif findtype 'bamboo flute'
                        dclicktype 'bamboo flute'
                    endif
                    @settimer  _sound  0
                    #cooldown 'skill' 6150
                endif
            endif

        endif
    endif
    

    while queued
    endwhile
endif

if __util__auto_close_house_gump == 1 and gumpexists 2490201206
    gumpclose 2490201206
endif

loop

