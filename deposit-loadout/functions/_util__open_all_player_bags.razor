#### todo trapped pouch
## (0 items, 33 stones)
##   note the trapped pouch
##   try to pull reagent/potion satchles out (to root-backpack?)
##   open them
##   then place back into said trapped pouch

@removelist  _util__open_all_player_bags__do_not_open_decoys__tmp_list
@createlist  _util__open_all_player_bags__do_not_open_decoys__tmp_list
#### make a copy of the decoy list to speed up processing later
if _util__open_all_player_bags__do_not_open_decoys == 1 and listexists _deposit_loadout_chain_loot_pouch_decoys
    foreach _itr in _deposit_loadout_chain_loot_pouch_decoys
        @pushlist _util__open_all_player_bags__do_not_open_decoys__tmp_list  _itr
    endfor
endif


foreach _a_depth in _util__open_player_bags__depth
    @setvar! _found_to_open 0

    if _a_depth == _util__open_all_player_bags__max_depth
        sysmsg  "open all bags, not opening beyond depth {{_util__open_all_player_bags__max_depth}}"  48
        break
    endif
    

    ## pouch :: 3705
    while @findtype! "pouch" backpack -1 -1 _a_depth as _this
        @getlabel! _this _this_label
        @ignore _this
        @setvar! _this_to_open 0
        #sysmsg _this_label
        if hue _this == 38
            if "(0 items, 0 stones)" in _this_label
            elseif "(0 items, " in _this_label
                @pushlist  _trapped_pouches_with_satchels  _this 
            endif
        else
            if 1 == _a_depth
                if _util__open_all_player_bags__do_not_open_empty_in_root == 1
                    if "(0 items" in _this_label
                    else
                        @setvar! _this_to_open 1
                        #@setvar! _found_to_open 1
                        #dclick _this
                    endif
                endif
            elseif 2 == _a_depth
                @setvar! _this_to_open 1
                #@setvar! _found_to_open 1
                #dclick _this
            else
                if _util__open_all_player_bags__do_not_open_empty_above_2_depth == 1
                    if "(0 items" in _this_label
                    else
                        @setvar! _this_to_open 1
                        #@setvar! _found_to_open 1
                        #dclick _this
                    endif
                endif
            endif
        endif

        if _this_to_open == 1 and _util__open_all_player_bags__do_not_open_decoys == 1
            foreach _itr in _util__open_all_player_bags__do_not_open_decoys__tmp_list
                if _itr == _this
                    @setvar! _this_to_open 0
                    @poplist _util__open_all_player_bags__do_not_open_decoys__tmp_list  _this
                    break
                endif
            endfor
        endif

        if _this_to_open == 1
            @setvar! _found_to_open 1
            dclick _this
        endif
    endwhile


    
    ## 3701 :: backpack
    ## 3702 :: bag
    ## 30765 :: wizard-s satchel :: reagent satchel
    ## 31262 :: potion satchel :: alchemists satchel
    ## 12215 :: quiver
    while @findtype! 3701|3702|30765|31262|12215 backpack -1 -1 _a_depth as _this
        @getlabel! _this _this_label
        @ignore _this
        @setvar! _this_to_open 0
        #sysmsg _this_label
        if 1 == _a_depth
            if _util__open_all_player_bags__do_not_open_empty_in_root == 1
                if "(0 items" in _this_label
                else
                    @setvar! _this_to_open 1
                    #@setvar! _found_to_open 1
                    #dclick _this
                endif
            endif
        elseif 2 == _a_depth
            @setvar! _this_to_open 1
            #@setvar! _found_to_open 1
            #dclick _this
        else
            if _util__open_all_player_bags__do_not_open_empty_above_2_depth == 1
                if "(0 items" in _this_label
                else
                    @setvar! _this_to_open 1
                    #@setvar! _found_to_open 1
                    #dclick _this
                endif
            endif
        endif

        if _this_to_open == 1 and _util__open_all_player_bags__do_not_open_decoys == 1
            foreach _itr in _util__open_all_player_bags__do_not_open_decoys__tmp_list
                if _itr == _this
                    @setvar! _this_to_open 0
                    @poplist _util__open_all_player_bags__do_not_open_decoys__tmp_list  _this
                    break
                endif
            endfor
        endif

        if _this_to_open == 1
            @setvar! _found_to_open 1
            dclick _this
        endif
    endwhile


    
    ## 24246 :: adventurer-s satchel :: book bind
    if _util__open_all_player_bags__only_root_adventures_satchel != 1
        while @findtype! "book bind" backpack -1 -1 _a_depth as _this
            @getlabel! _this _this_label
            @ignore _this
            #sysmsg _this_label
            @setvar! _found_to_open 1
            dclick _this
        endwhile
    endif

    if _found_to_open == 0
        break
    endif


endfor





## 24246 :: adventurer-s satchel :: book bind
if _util__open_all_player_bags__only_root_adventures_satchel == 1
    while @findtype! "book bind" backpack -1 -1 1 as _this
        @getlabel! _this _this_label
        @ignore _this
        #sysmsg _this_label
        dclick _this
    endwhile
endif



## 30765 :: wizard-s satchel :: reagent satchel
## 31262 :: potion satchel :: alchemists satchel
## 12215 :: quiver
while @findtype! 30765|31262|12215 self -1 -1 1 as _this
    @getlabel! _this _this_label
    @ignore _this
    #sysmsg _this_label
    dclick _this
endwhile




