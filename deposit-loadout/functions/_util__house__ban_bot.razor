#### logic - dont edit below
### cleanup tmp items
while inlist  __util__do_not_ban__list  0  
    @poplist  __util__do_not_ban__list  0
endwhile
while  inlist  __util__do_not_ban__list  0x0
    @poplist  __util__do_not_ban__list  0x0
endwhile

if not dead
    @clearsysmsg

    if targetexists
        hotkey 'cancel current target'
    endif

    hotkey 'Next non-friendly player target'
    @getlabel! backpack _bp

    if not insysmsg 'No one matching that was found on your screen.'
        @setvar!  _target  lasttarget
        if  not inlist  _util__house__ban_bot__ignores  _target  and  not inlist  __util__do_not_ban__list
            say "i ban thee" 
            wft 500
            target _target
            @getlabel! backpack _bp
            if insysmsg "You cannot eject a friend of the house!"
                @pushlist  _util__house__ban_bot__ignores  removeTarget 
            endif  
        endif
    endif

    while queued
    endwhile
endif


#wait 600
#sysmsg "util house ban bot - complete"




