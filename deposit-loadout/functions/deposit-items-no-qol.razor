
sysmsg "deposit items no qol - start"
#@setvar! _this_script "Play Script: deposit-loadout\functions\deposit-items-no-qol"

#### for when no tome/vault/rack/ect exists, use a chest instead



    #### prev-trunks
    ## train coal :: dirt patch :: id 2323 hue 2500
    ## train track :: toy train track :: 48352
    ## train track [turn] :: snow covered track :: 60209
    ## train track [straight] :: snow covered track :: 60125
    ## popcorn train car :: popcorn train :: 56037
    ## a train engine :: wooden train engine :: 65287
@setvar! _seasonal_and_events__crate  _deposit_loadout__chest__seasonal_and_events
while @findtype! 54232|39857|52615  backpack as _this
    ## halloween 2025 prev scratch ticket :: scratch ticket :: i65066 h2493
    ## snowballs :: snowball :: 54232
    ## cupid arrow bundle :: 39857
    ## mending arrow :: 52615
    #@ignore! _this
    @getlabel! _this _this_label
    sysmsg _this_label 11

    @getlabel! _seasonal_and_events__crate  _this_chest_label
    if "125 items" in _this_chest_label
        overhead "seasonal and events stuff crate full"
        dclick  _seasonal_and_events__crate
        break
    endif

    lift _this 60000
    drop _seasonal_and_events__crate  -1 -1 -1
    #@getlabel! backpack _this_label
    while queued
        #@getlabel! backpack _this_label
    endwhile
    #@getlabel! backpack _this_label
endwhile





##### arcane runes
if _deposit_loadout__tomes__arcane_rune_tome == 0
    @setvar!  _this_chest  _deposit_loadout__chest__arcane_runes
    while @findtype! "rune"  backpack as _this
        #@ignore! _this
        @getlabel! _this _this_label
        sysmsg _this_label 11

        @getlabel!  _this_chest  _this_chest_label
        if "125 items" in _this_chest_label
            overhead "arcane rune crate full"
            dclick  _this_chest
            break
        endif

        if "double click to place" in _this_label
            lift  _this 60000
            drop  _this_chest  -1 -1 -1
            #@getlabel! backpack _this_label
            while queued
                #@getlabel! backpack _this_label
            endwhile
            #@getlabel! backpack _this_label
        endif
    endwhile
endif





##### carpet
if _deposit_loadout__menuable__carpet_rack == 0
    @setvar!  _this_chest  _deposit_loadout__chest__carpets
    while @findtype! "carpet"  backpack as _this
        #@ignore! _this
        @getlabel! _this _this_label
        sysmsg _this_label 11

        @getlabel!  _this_chest  _this_chest_label
        if "125 items" in _this_chest_label
            overhead "carpet crate full"
            dclick  _this_chest
            break
        endif

        lift  _this 60000
        drop  _this_chest  -1 -1 -1
        #@getlabel! backpack _this_label
        while queued
            #@getlabel! backpack _this_label
        endwhile
        #@getlabel! backpack _this_label
    endwhile
endif





while queued
endwhile



@getlabel! backpack _this_label
#wait 100
sysmsg "deposit items no qol - complete"




