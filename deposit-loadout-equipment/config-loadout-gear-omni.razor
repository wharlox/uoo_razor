    if not listexists _util__loadout__previous_label_checker
        sysmsg "first run"
        @createlist _util__loadout__previous_label_checker
        foreach _itr in _util__loadout__profile_name
            @pushlist _util__loadout__previous_label_checker _itr
        endfor
    else
        foreach _now in _util__loadout__profile_name
            foreach _p in _util__loadout__previous_label_checker
                if _now == _p
                    #sysmsg "eq  {{_p}}"
                else
                    #sysmsg "neq   {{_now}} != {{_p}}"
                    if not varexist _util__loadout__temp_var__previous_label_checker
                        @setvar _util__loadout__temp_var__previous_label_checker 1
                        sysmsg "play script again to confirm loadout change from `{{_p}}` to `{{_now}}`" 43
                        stop
                    else
                        sysmsg "successfully activated `{{_now}}` - was `{{_p}}`" 44
                        @unsetvar _util__loadout__temp_var__previous_label_checker
                        @poplist _util__loadout__previous_label_checker front
                        @pushlist _util__loadout__previous_label_checker _now
                    endif
                endif
            endfor
        endfor
    endif
