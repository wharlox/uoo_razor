sysmsg "__start equpping special gear"





if not varexist _util__equip_gear__source__gear_bag__or__magic_item_vault or not varexist _util__loadout__serial__storage_shelf or not listexists _util__equipment_storage__nested_gear_bag_serials
    overhead "ERROR- vars not set, restart the run-loadout-equip-special script" 33
    sysmsg "ERROR- vars not set, restart the run-loadout-equip-special script" 33

    unsetvar _util__equip_gear__source__gear_bag__or__magic_item_vault
    unsetvar _util__loadout__serial__storage_shelf
    removelist _util__equipment_storage__nested_gear_bag_serials
    stop
endif





@setvar _util__equip_gear__final_storage_chest 0
if _util__unequip_gear__store_dst__gear_bag__or__magic_item_vault == 1
    foreach _itr in _util__equipment_storage__nested_gear_bag_serials
        @setvar _util__equip_gear__final_storage_chest  _itr
        dclick _itr
        @getlabel! _itr _label
        wait 420
    endfor
endif


@removelist  _util__gear_found
@createlist  _util__gear_found






#### detect if any gear is equipped and abort
if findlayer self head or findlayer self neck or findlayer self arms or findlayer self gloves or findlayer self innertorso or findlayer self pants or findlayer self righthand or findlayer self lefthand or findlayer self quiver or  findlayer self outerbody 
    sysmsg "ERROR: detected gear already equipped - will not start equiping gear"  33
    overhead "ERROR: detected gear already equipped - will not start equiping gear"  33
    
    unsetvar _util__equip_gear__source__gear_bag__or__magic_item_vault
    unsetvar _util__loadout__serial__storage_shelf
    removelist _util__equipment_storage__nested_gear_bag_serials
    stop
endif








#### equip gear from specified chest
if _util__equip_gear__source__gear_bag__or__magic_item_vault == 1

    @clearignore
    ## find serial src hue qty range
    while findtype '5056|5059|5060|5061|5063|5070|5074|5075|5076|5078|5085|5089|5090|5101|5103|5105|5106|5129|5131|5132|5135|5138|5139|5142|5143|5144|5146|5201|5203|5204|5205|5207|7169|7170|7173|7175|7177|7179|7181|7610|7947|31003|31004|31005|31006|31007|31008|31009|31010|31011|31012|31015|31191'  _util__equip_gear__final_storage_chest  -1 -1 1 as _this
        @getlabel! _this _label
        sysmsg "{{_this}} - {{_label}}" 99
        @pushlist  _util__gear_found  _this
        dclick _this

        wait _lift_drop_delay_ms
        @getlabel! backpack _label
        @ignore _this
    endwhile

    ## 
    while findtype 'quiver|alchemists satchel|reagent satchel' _util__equip_gear__final_storage_chest  -1 -1 1 as _this
        @getlabel! _this _label
        sysmsg "{{_this}} - {{_label}}" 99
        @pushlist  _util__gear_found  _this
        
        lift _this
        if "quiver" in _label
            drop self quiver
        elseif "satchel" in _label and not findlayer self outerbody
            drop self outerbody
        else
            drop backpack -1 -1
        endif

        wait _lift_drop_delay_ms
        @getlabel! backpack _label
        @ignore _this
    endwhile



    #### equip weapons
    ## wrestling     - 22187|31141|31142
    ## spellbooks    - 3570|3571|3572|3573|3834
    ## archery       - 3920|5042|5117|30990|30993|30994|30995|31184|31186
    ## shields       - 7026|7027|7029|7031|7033|7034|7035|7107|7109|31002|31130
    ## fencing       - 3719|3922|3938|5121|5123|5125|30989|30992|30996|30997|30998|31176|31188
    ## swords        - 3909|3911|3913|3915|3917|3934|3937|5046|5049|5115|5119|5182|5185|5187|30988|31128|31190
    ## maces         - 3568|3713|3721|3932|5040|5044|5112|5127|5177|5179|5181|30991|30999|31000|31001|31014|31178|31180|31182
    ## arcane staffs - 31017|31019|31021|31023|31025|31027|31029|31031|31033|31035|31037|31038|31041|31043|31045|31047|31049|31051|31053|31055
    ## throwing      - 67713|67723|67734|67744|67754|67764|chakram|francisca|hurlbat|javelin|throwing knife|throwing star
    ## dual wield    - 67773|67774|67775|67776|67777|67778|dual wield tracker knife|duel wield katana|dual wield norse axe|dual wield rapier|dual wield sabre|dual wield scimitar

    #### backpack items
    ## instruments - 3740|3742|3762|3763|10245|20006|20008|20010|20012|20014|20016


    ## equipable weapons
    while findtype '22187|31141|31142|3570|3571|3572|3573|3834|3920|5042|5117|30990|30993|30994|30995|31184|31186|7026|7027|7029|7031|7033|7034|7035|7107|7109|31002|31130|3719|3922|3938|5121|5123|5125|30989|30992|30996|30997|30998|31176|31188|3909|3911|3913|3915|3917|3934|3937|5046|5049|5115|5119|5182|5185|5187|30988|31128|31190|3568|3713|3721|3932|5040|5044|5112|5127|5177|5179|5181|30991|30999|31000|31001|31014|31178|31180|31182|31017|31019|31021|31023|31025|31027|31029|31031|31033|31035|31037|31038|31041|31043|31045|31047|31049|31051|31053|31055|67713|67723|67734|67744|67754|67764|chakram|francisca|hurlbat|javelin|throwing knife|throwing star|67773|67774|67775|67776|67777|67778|dual wield tracker knife|duel wield katana|dual wield norse axe|dual wield rapier|dual wield sabre|dual wield scimitar'  _util__equip_gear__final_storage_chest  -1 -1 1 as _this
        @getlabel _this _label
        sysmsg "{{_this}} - {{_label}}" 99
        @pushlist  _util__gear_found  _this

        if "throwing knife" in _label  or  "dagger" in _label
            lift _this
            drop backpack -1 -1
        else
            dclick _this
            wait _lift_drop_delay_ms
            @getlabel! backpack _label
        endif
    endwhile
    
    if not listexists _loadout__active_instrument
        createlist _loadout__active_instrument
    endif
    ## instruments
    while findtype '3740|3742|3762|3763|10245|20006|20008|20010|20012|20014|20016'  _util__equip_gear__final_storage_chest  -1 -1 1 as _this
        @getlabel _this _label
        sysmsg "{{_this}} - {{_label}}" 99
        @pushlist  _util__gear_found  _this
        
        @setvar! _hate_this 0
        while _hate_this == 0
            if _this in _loadout__active_instrument
                poplist _loadout__active_instrument _this
            else
                @setvar! _hate_this 1
            endif
        endwhile
        pushlist _loadout__active_instrument _this
        
        lift _this
        drop backpack -1 -1

        wait _lift_drop_delay_ms
        @getlabel! backpack _label
    endwhile
    
