### unequip armor
@setvar _lift_drop_delay_ms 420

if findlayer self head as _this
    @getlabel! _this _label
    if "blessed" in _label
        lift _this
        drop backpack -1 -1
    else
        if "exceptional" in _label and "aspect" in _label
            lift _this
            drop _util__loadout__serial__storage_shelf

            @getlabel! _this _label
            wait _lift_drop_delay_ms
            lift _this
            drop _util__loadout__serial__storage_shelf
        elseif "exceptional" in _label
            lift _this
            drop _util__loadout__serial__storage_shelf
