@setvar  _util__scavenger__pickup__time  500
@removetimer  _util__scavenger__pickup
@settimer  _util__scavenger__pickup  _util__scavenger__pickup__time

while not dead

@removelist  _util__scavenger__found
@createlist  _util__scavenger__found
    @clearignore 
    foreach  _itr  in  _util__scavenger__list
        #overhead _itr
        while @findtype  _itr  ground -1 -1 2 as _found
            if timer _util__scavenger__pickup >=  _util__scavenger__pickup__time
                hotkey "Grab Item"
                wft 500
                target _found
                #lift _found  
                #60000
                #@drop backpack -1 -1 -1
                @settimer  _util__scavenger__pickup  0
            else
                @pushlist  _util__scavenger__found  _found
            endif
            @ignore  _found
        endwhile
    endfor

    foreach _itr in  _util__scavenger__found
        if timer _util__scavenger__pickup >=  _util__scavenger__pickup__time
            hotkey "Grab Item"
            wft 500
            target _itr
            #@lift _itr 60000
            #@drop backpack -1 -1 -1
            @settimer  _util__scavenger__pickup  0
        endif
    endfor

endwhile
